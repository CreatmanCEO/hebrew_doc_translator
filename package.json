{
  "name": "hebrew-doc-translator",
  "version": "1.0.0",
  "description": "Hebrew document translator with format preservation (monorepo root)",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/api",
    "packages/client"
  ],
  "scripts": {
    "start": "npm run start -w @hdt/api",
    "dev": "npm run dev -w @hdt/api",
    "client": "npm run start -w @hdt/client",
    "worker": "npm run worker -w @hdt/api",
    "dev:full": "concurrently \"npm run dev -w @hdt/api\" \"npm run start -w @hdt/client\"",
    "test": "cross-env NODE_ENV=test vitest run --passWithNoTests",
    "test:watch": "cross-env NODE_ENV=test vitest watch",
    "test:coverage": "cross-env NODE_ENV=test vitest run --coverage",
    "test:e2e": "playwright test",
    "test:integration": "cross-env NODE_ENV=test jest --config jest.integration.js --passWithNoTests",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.9",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-node": "^11.1.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "msw": "^2.1.3",
    "nodemon": "^3.0.2",
    "prettier": "^3.2.4",
    "supertest": "^6.3.4",
    "testcontainers": "^10.4.0",
    "vitest": "^2.1.9",
    "vitest-mock-extended": "^2.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
